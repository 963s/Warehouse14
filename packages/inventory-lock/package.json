{
  "name": "@warehouse14/inventory-lock",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Atomic inventory reservation for Warehouse14. The single discipline boundary for products.status mutations.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .tsbuildinfo"
  },
  "dependencies": {
    "@warehouse14/db": "workspace:*",
    "drizzle-orm": "0.36.4"
  },
  "devDependencies": {
    "@warehouse14/config": "workspace:*",
    "typescript": "5.7.2"
  }
}
