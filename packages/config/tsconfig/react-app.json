{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Warehouse14 React app (Vite + Tauri WebView)",
  "extends": "./base.json",
  "compilerOptions": {
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "declaration": false,
    "noEmit": true,
    "sourceMap": true,
    "incremental": true,
    "tsBuildInfoFile": ".tsbuildinfo",
    "types": ["vite/client"]
  }
}
