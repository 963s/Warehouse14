{
  "name": "@warehouse14/ui-kit",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Brand primitives for Warehouse14 — Seal, RomanIndex, IlluminatedCapital, DiamondRule, ParchmentCard, MagnifierIcon, WaxSealBadge. Source of truth: memory.md §10 [VISUAL_IDENTITY_GUIDELINES].",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css",
    "./tokens.css": "./dist/tokens.css",
    "./typography.css": "./dist/typography.css"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc && node ./scripts/copy-styles.mjs",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "clean": "rm -rf dist .tsbuildinfo storybook-static"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "devDependencies": {
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "@warehouse14/config": "workspace:*",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "typescript": "5.7.2"
  }
}
