{
  "name": "@warehouse14/api-client",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Typed HTTP client for the Warehouse14 frozen API. Re-uses TypeBox schemas from the backend — no codegen, no drift.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist .tsbuildinfo"
  },
  "dependencies": {
    "@sinclair/typebox": "0.32.35"
  },
  "devDependencies": {
    "@warehouse14/config": "workspace:*",
    "typescript": "5.7.2",
    "vitest": "2.1.8"
  }
}
