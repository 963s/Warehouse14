auto-install-peers=true
strict-peer-dependencies=false
# Hoisted linking (Expo SDK 55 default for monorepos). The isolated/symlinked
# layout makes nativewind 5 / react-native-css's globalClassNamePolyfill resolve
# `react-native` back to its own shim → infinite require loop → "Maximum call
# stack size exceeded" at cold start in RELEASE builds only. Hoisting removes the
# symlink ambiguity. See nativewind/react-native-css#256.
node-linker=hoisted
shamefully-hoist=false
prefer-workspace-packages=true
link-workspace-packages=true
save-workspace-protocol=rolling
