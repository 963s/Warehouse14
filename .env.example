# ──────────────────────────────────────────────────────────────
# goldhaus — Environment Variables Template
# Copy to .env (gitignored) and fill in real values.
# ──────────────────────────────────────────────────────────────

# ─── Database ─────────────────────────────────────────────────
# PostgreSQL connection string for local development.
# Defaults match infrastructure/docker/docker-compose.yml.
DATABASE_URL="postgresql://goldhaus:goldhaus_dev_pw@localhost:5432/goldhaus_dev"

# ─── API Server ───────────────────────────────────────────────
API_HOST="127.0.0.1"
API_PORT="3001"
NODE_ENV="development"

# Required in production. Length >= 32 chars.
# Generate with: openssl rand -hex 32
AUTH_SECRET=""

# ─── Redis (event bus & job queue) ────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── Fiskaly TSE (Phase 2+) ───────────────────────────────────
# FISKALY_API_KEY=""
# FISKALY_API_SECRET=""
# FISKALY_ENVIRONMENT="test"  # test | live

# ─── Object Storage (Phase 2+) ────────────────────────────────
# Cloudflare R2 — product photos, public CDN, zero egress
# R2_ACCOUNT_ID=""
# R2_ACCESS_KEY_ID=""
# R2_SECRET_ACCESS_KEY=""
# R2_BUCKET_NAME="goldhaus-media"

# AWS S3 Glacier — GoBD 10-year legal archive (EU region)
# S3_GLACIER_ACCESS_KEY_ID=""
# S3_GLACIER_SECRET_ACCESS_KEY=""
# S3_GLACIER_BUCKET="goldhaus-archive"
# S3_GLACIER_REGION="eu-central-1"

# ─── External APIs (Phase 2+) ─────────────────────────────────
# WHATSAPP_PHONE_NUMBER_ID=""
# WHATSAPP_ACCESS_TOKEN=""
# WHATSAPP_VERIFY_TOKEN=""
# PHOTOROOM_API_KEY=""
# OPENAI_API_KEY=""
# EBAY_APP_ID=""
# EBAY_CERT_ID=""
# EBAY_DEV_ID=""

# ─── Gold price feed (Phase 1) ────────────────────────────────
# Default uses LBMA free JSON feed; no key required.
# Optional commercial fallback:
# GOLD_API_KEY=""  # goldapi.io or metalpriceapi.com
