{
  "name": "warehouse14",
  "private": true,
  "version": "0.1.0",
  "description": "Hybrid Cloud/Desktop ERP & POS for gold, rare coins, and antiques — German GoBD compliant",
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.18.0",
    "pnpm": ">=9.15.0"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "pnpm --filter @warehouse14/db build && pnpm -r build",
    "test": "pnpm -r test",
    "lint": "node scripts/lint-added.mjs",
    "lint:all": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "pnpm --filter @warehouse14/db build && pnpm -r build && pnpm -r typecheck",
    "clean": "turbo clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "turbo": "2.3.3",
    "typescript": "5.7.2"
  }
}
