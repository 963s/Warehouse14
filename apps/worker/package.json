{
  "name": "@warehouse14/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Warehouse14 background daemon — PG-native cron scheduler + advisory-locked job runner + retry/DLQ + Prometheus metrics. See memory.md #63.",
  "main": "./dist/server.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist .tsbuildinfo coverage"
  },
  "dependencies": {
    "@fastify/sensible": "5.6.0",
    "@sinclair/typebox": "0.32.35",
    "@warehouse14/audit": "workspace:*",
    "@warehouse14/db": "workspace:*",
    "@warehouse14/inventory-lock": "workspace:*",
    "close-with-grace": "1.3.0",
    "drizzle-orm": "0.36.4",
    "fastify": "4.28.1",
    "fastify-metrics": "11.0.0",
    "node-cron": "3.0.3",
    "postgres": "3.4.5",
    "prom-client": "15.1.3"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "10.13.2",
    "@types/node": "20.17.10",
    "@types/node-cron": "3.0.11",
    "@vitest/coverage-v8": "2.1.8",
    "@warehouse14/config": "workspace:*",
    "testcontainers": "10.13.2",
    "tsx": "4.19.2",
    "typescript": "5.7.2",
    "vitest": "2.1.8"
  }
}
