<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Code-signing entitlements for Warehouse14 POS (macOS).

  Referenced from tauri.conf.json -> bundle.macOS.entitlements.

  IMPORTANT. The hardened runtime is ON even for our ad-hoc ("-") build.
  Tauri's bundler signs with the runtime option enabled by default
  (hardenedRuntime is not disabled in tauri.conf.json), so it applies to the
  ad-hoc signature too. That means the resource-access entitlements below are
  ENFORCED right now, not only on a future Developer-ID / notarized build. Do
  NOT delete a device entitlement believing "ad-hoc ignores it", it does not,
  and removing one silently denies that capability below the web layer.

    com.apple.security.device.camera
        Grants the in-app camera (Foto-Werkstatt getUserMedia). Without it the
        WKWebview camera request is refused before the web layer and
        getUserMedia rejects.

    com.apple.security.device.audio-input
        Grants the microphone (Vierzehn voice assistant getUserMedia). Exact
        parity with the camera above: NSMicrophoneUsageDescription in
        Info.plist covers the TCC prompt, but under the hardened runtime the
        capture is still refused unless this entitlement is present. Its
        absence was the root cause of "Kein Zugriff auf das Mikrofon".

    com.apple.security.cs.allow-jit
    com.apple.security.cs.allow-unsigned-executable-memory
        JavaScriptCore (the WKWebview engine) requires JIT / unsigned
        executable memory under the hardened runtime.
-->
<plist version="1.0">
  <dict>
    <key>com.apple.security.device.camera</key>
    <true/>
    <key>com.apple.security.device.audio-input</key>
    <true/>
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
  </dict>
</plist>
