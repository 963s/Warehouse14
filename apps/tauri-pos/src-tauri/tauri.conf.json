{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Warehouse14 POS",
  "version": "0.4.20",
  "identifier": "de.warehouse14.pos",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Warehouse14 — POS",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true,
        "decorations": true,
        "maximized": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: blob: https://api.warehouse14.de https://media.warehouse14.de https://chat.warehouse14.de; style-src 'self' 'unsafe-inline'; font-src 'self' data:; script-src 'self' https://chat.warehouse14.de; connect-src 'self' http://localhost:3001 https://api.warehouse14.de https://chat.warehouse14.de wss://chat.warehouse14.de; frame-src https://chat.warehouse14.de https://calendar.google.com"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "nsis", "deb", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "10.15",
      "signingIdentity": "-",
      "entitlements": "Entitlements.plist"
    },
    "windows": {
      "wix": null,
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installMode": "currentUser",
        "languages": ["English", "German"],
        "displayLanguageSelector": false
      }
    },
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "active": true,
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQxMDE4MTMxRUEyQ0Q4MkQKUldRdDJDenFNWUVCUWRteFY4elhqUjZNV0xKTGNDcEJLZUdYQXFualV2akEwYjRWa0ZhYVRoTTIK",
      "endpoints": [
        "https://github.com/__GITHUB_OWNER__/__GITHUB_REPO__/releases/latest/download/latest.json"
      ]
    }
  }
}
