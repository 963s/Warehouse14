{
  "name": "@warehouse14/api-cloud",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Warehouse14 Cloud API — Fastify + TypeBox + better-auth + mTLS + pg_notify SSE",
  "main": "./dist/server.js",
  "scripts": {
    "build": "tsc",
    "dev:bootstrap": "tsx scripts/dev-bootstrap.ts",
    "dev": "pnpm run dev:bootstrap && tsx watch src/server.ts",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist .tsbuildinfo coverage"
  },
  "dependencies": {
    "@fastify/cookie": "9.4.0",
    "@aws-sdk/client-s3": "3.700.0",
    "@aws-sdk/s3-request-presigner": "3.700.0",
    "@fastify/cors": "10.1.0",
    "@fastify/helmet": "12.0.1",
    "@fastify/rate-limit": "9.1.0",
    "@fastify/sensible": "5.6.0",
    "@fastify/swagger": "8.15.0",
    "@fastify/swagger-ui": "4.2.0",
    "@sinclair/typebox": "0.32.35",
    "@warehouse14/audit": "workspace:*",
    "@warehouse14/auth-pin": "workspace:*",
    "@warehouse14/db": "workspace:*",
    "@warehouse14/domain": "workspace:*",
    "@warehouse14/inventory-lock": "workspace:*",
    "better-auth": "1.3.34",
    "close-with-grace": "1.3.0",
    "drizzle-orm": "0.36.4",
    "fastify": "4.28.1",
    "fastify-metrics": "11.0.0",
    "fastify-plugin": "4.5.1",
    "postgres": "3.4.5"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "10.13.2",
    "@types/node": "20.17.10",
    "@types/node-forge": "1.3.14",
    "@vitest/coverage-v8": "2.1.8",
    "@warehouse14/config": "workspace:*",
    "node-forge": "1.4.0",
    "testcontainers": "10.13.2",
    "tsx": "4.19.2",
    "typescript": "5.7.2",
    "vitest": "2.1.8"
  }
}
