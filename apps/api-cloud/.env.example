# Warehouse14 Cloud API — environment template.
# Copy to .env.local for development; production values come from Oracle Vault.

# Server
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug                                     # info in prod, debug in dev

# Database
DATABASE_URL=postgres://warehouse14_app:warehouse14_app_dev_pw@localhost:5432/warehouse14
DB_POOL_MAX=10

# PII encryption key — used by withPiiKey() / per-request SET LOCAL hook.
# In production this comes from Oracle Vault; never commit a real key.
WAREHOUSE14_PII_KEY=dev-pii-key-do-not-use-in-production-32b

# CORS / trusted origins (comma-separated; better-auth uses this list)
TRUSTED_ORIGINS=http://localhost:3000,http://localhost:5173

# Transactions above this total (EUR) require a fresh PIN step-up before finalize.
# ADR-0022 §4c. NUMERIC(18,2) string format.
TRANSACTION_STEP_UP_THRESHOLD_EUR=1000.00

# Cloudflare R2 — product photo storage (Day 16). Leave empty in dev if the
# photo endpoint is unused; the route returns 500 INTERNAL_ERROR on missing
# config rather than silently failing.
R2_ACCOUNT_ID=
R2_BUCKET=warehouse14-products
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PUBLIC_URL_BASE=https://media.warehouse14.de

# ── Stripe (Day 19) — primary online payment provider ─────────────────────
# memory.md #65 amends #31: Stripe is now primary for V1 (SEPA + Klarna +
# iDEAL + German cards via the unified PaymentIntents API). Leave empty in
# dev when the storefront isn't exercised; /checkout + /webhooks/stripe
# refuse with 500 if invoked without these set.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_WEBHOOK_TOLERANCE_SECONDS=300
STRIPE_API_VERSION=2024-12-18.acacia
