{
  "extends": "@warehouse14/config/tsconfig/react-app.json",
  "compilerOptions": {
    /* ── React Native / Expo module resolution (mirrors expo/tsconfig.base) ── */
    "jsx": "react-jsx",
    "lib": [
      "esnext",
      "dom"
    ],
    "module": "esnext",
    "moduleResolution": "bundler",
    "customConditions": [
      "react-native"
    ],
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "sourceMap": true,
    /* Expo provides its own ambient types; drop the Vite client types the
       shared react-app preset pulls in (this is a native app, not a web app). */
    "types": [],
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@assets/*": [
        "./assets/*"
      ]
    },
    "typeRoots": [
      "./node_modules/@types",
      "./types"
    ],
    /* The shared base is authored for first-party library code. Expo's
       boilerplate (and React Native's own d.ts) does not satisfy these four
       flags, so relax them at the app boundary while keeping `strict: true`. */
    "verbatimModuleSyntax": false,
    "exactOptionalPropertyTypes": false,
    "noUncheckedIndexedAccess": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "nativewind-env.d.ts"
  ],
  "exclude": [
    "node_modules",
    "test/**/*",
    "**/*.test.ts",
    "**/*.test.tsx",
    "app.config.ts",
    "dist",
    ".expo"
  ]
}