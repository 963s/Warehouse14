# Scoped fallback for the mobile app only — the repo root stays pnpm-isolated
# (symlinked). This file is read only when pnpm is invoked from inside
# apps/mobile; a root `pnpm install` ignores it. Kept here as the documented
# escape hatch: if a React Native native module refuses to resolve under the
# isolated store, install from this directory to get a flat (hoisted) layout.
node-linker=hoisted
public-hoist-pattern[]=*
