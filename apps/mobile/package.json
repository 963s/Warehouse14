{
  "name": "@warehouse14/mobile",
  "version": "0.0.1",
  "private": true,
  "main": "index.js",
  "scripts": {
    "dev": "expo start",
    "build": "expo export",
    "typecheck": "tsc --noEmit",
    "start": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "bundle:web": "npx expo export --platform web",
    "serve:web": "npx serve dist",
    "prebuild:clean": "npx expo prebuild --clean",
    "compile": "tsc --noEmit -p . --pretty",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "depcruise": "depcruise src --config .dependency-cruiser.js",
    "align-deps": "npx expo install --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:guard": "jest --config jest.guard.config.js",
    "test:maestro": "maestro test -e MAESTRO_APP_ID=de.warehouse14.mobile .maestro/flows",
    "adb": "adb reverse tcp:9090 tcp:9090 && adb reverse tcp:3000 tcp:3000 && adb reverse tcp:9001 tcp:9001 && adb reverse tcp:8081 tcp:8081",
    "build:ios:sim": "eas build --profile development --platform ios --local",
    "build:ios:device": "eas build --profile development:device --platform ios --local",
    "build:ios:preview": "eas build --profile preview --platform ios --local",
    "build:ios:prod": "eas build --profile production --platform ios --local",
    "build:android:sim": "eas build --profile development --platform android --local",
    "build:android:device": "eas build --profile development:device --platform android --local",
    "build:android:preview": "eas build --profile preview --platform android --local",
    "build:android:prod": "eas build --profile production --platform android --local"
  },
  "dependencies": {
    "@expo-google-fonts/bricolage-grotesque": "0.4.1",
    "@expo-google-fonts/inter": "^0.4.0",
    "@expo-google-fonts/jetbrains-mono": "^0.4.0",
    "@expo/metro-runtime": "~55.0.6",
    "@react-navigation/native": "^7.0.14",
    "@rn-primitives/dialog": "^1.4.0",
    "@rn-primitives/portal": "^1.4.0",
    "@rn-primitives/slot": "^1.4.0",
    "@warehouse14/api-client": "workspace:*",
    "@warehouse14/domain": "workspace:*",
    "@warehouse14/i18n-de": "workspace:*",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "expo": "55.0.26",
    "expo-build-properties": "~55.0.9",
    "expo-file-system": "~55.0.22",
    "expo-font": "~55.0.4",
    "expo-image": "^55.0.11",
    "expo-image-manipulator": "^55.0.17",
    "expo-image-picker": "~55.0.21",
    "expo-linking": "~55.0.7",
    "expo-localization": "~55.0.8",
    "expo-print": "~55.0.8",
    "expo-router": "~55.0.4",
    "expo-sharing": "~55.0.11",
    "expo-splash-screen": "~55.0.10",
    "expo-system-ui": "~55.0.9",
    "lucide-react-native": "^1.20.0",
    "nativewind": "5.0.0-preview.4",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-css": "^3.0.7",
    "react-native-edge-to-edge": "~1.6.1",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-get-random-values": "~1.11.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.5",
    "react-native-vision-camera": "4.7.3",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.7.4",
    "setimmediate": "^1.0.5",
    "tailwind-merge": "^3.6.0"
