  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@babel/preset-env": "^7.20.0",
    "@babel/runtime": "^7.20.0",
    "@tailwindcss/postcss": "^4.3.1",
    "@testing-library/react-native": "^13.2.0",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.10",
    "@warehouse14/config": "workspace:*",
    "babel-jest": "^29.2.1",
    "babel-preset-expo": "~55.0.22",
    "dependency-cruiser": "^17.0.2",
    "eslint": "^8.57.0",
    "eslint-config-expo": "~55.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-react-native": "^4.1.0",
    "eslint-plugin-reactotron": "^0.1.2",
    "jest": "~29.7.0",
    "jest-expo": "~55.0.9",
    "postcss": "^8.5.15",
    "prettier": "^3.3.3",
    "react-test-renderer": "19.2.0",
    "reactotron-core-client": "^2.9.4",
    "reactotron-react-js": "^3.3.11",
    "reactotron-react-native": "^5.0.5",
    "reactotron-react-native-mmkv": "^0.2.6",
    "tailwindcss": "^4.3.1",
    "ts-jest": "^29.1.1",
    "tsx": "^4.20.3",
    "typescript": "~5.9.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
