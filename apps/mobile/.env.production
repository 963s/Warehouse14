# Release/production env. Expo loads this in production bundling (export:embed)
# with higher precedence than .env, so a release build NEVER inherits the dev
# localhost from .env. The shipped app talks to the live API.
#
# Keep this file free of dev-only bypasses (no EXPO_PUBLIC_DEV_DEVICE_FINGERPRINT).
EXPO_PUBLIC_API_BASE_URL=https://api.warehouse14.de
