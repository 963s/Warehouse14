{
  "name": "@warehouse14/storefront-mobile",
  "version": "1.0.0",
  "private": true,
  "main": "index.js",
  "type": "module",
  "description": "Public customer storefront app for Warehouse14 (Android first, iOS next). Consumes the same api.warehouse14.de catalog as the web storefront.",
  "scripts": {
    "dev": "expo start",
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "compile": "tsc --noEmit -p . --pretty",
    "prebuild:clean": "npx expo prebuild --clean",
    "build:android:release": "cd android && ./gradlew :app:bundleRelease :app:assembleRelease"
  },
  "dependencies": {
    "@expo-google-fonts/bricolage-grotesque": "0.4.1",
    "@expo-google-fonts/inter": "^0.4.0",
    "@expo-google-fonts/jetbrains-mono": "^0.4.0",
    "@expo/metro-runtime": "~55.0.6",
    "@react-native-async-storage/async-storage": "2.1.2",
    "@react-navigation/native": "^7.0.14",
    "@warehouse14/api-client": "workspace:*",
    "@warehouse14/domain": "workspace:*",
    "clsx": "^2.1.1",
    "expo": "55.0.5",
    "expo-build-properties": "~55.0.9",
    "expo-clipboard": "~8.0.10",
    "expo-font": "~55.0.4",
    "expo-haptics": "~15.0.10",
    "expo-image": "~3.2.0",
    "expo-linear-gradient": "~14.2.0",
    "expo-linking": "~55.0.7",
    "expo-localization": "~55.0.8",
    "expo-router": "~55.0.4",
    "expo-splash-screen": "~55.0.10",
    "expo-status-bar": "~3.2.0",
    "expo-system-ui": "~55.0.9",
    "expo-web-browser": "~14.2.0",
    "lucide-react-native": "^1.20.0",
    "nativewind": "5.0.0-preview.4",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-css": "^3.0.7",
    "react-native-edge-to-edge": "~1.6.1",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-get-random-values": "~1.11.0",
    "react-native-pager-view": "6.8.4",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-worklets": "0.7.2",
    "setimmediate": "^1.0.5",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@babel/preset-env": "^7.20.0",
    "@babel/runtime": "^7.20.0",
    "@tailwindcss/postcss": "^4.3.1",
    "@warehouse14/config": "workspace:*",
    "babel-preset-expo": "^55.0.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^4.3.1",
    "typescript": "5.7.2"
  }
}
