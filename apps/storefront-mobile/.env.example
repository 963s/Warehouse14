# Public storefront app, environment shape (NO secrets, this is public config).
#
# The real values are injected at build time. The app always points at the
# live public catalog. Copy to .env and adjust only for local development.

# The public API base. The web storefront uses the same one.
EXPO_PUBLIC_API_BASE_URL=https://api.warehouse14.de

# Optional: a stripe publishable key for inline card payment (DSGVO: only set
# when the owner enables card checkout in the storefront; the API issues the
# PaymentIntent server side and returns the client_secret).
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=
