# Chatwoot self-host env — copy to `.env` next to docker-compose.chatwoot.yml.
# Generate secrets with: openssl rand -hex 32

# ── Core ────────────────────────────────────────────────────────────────────
SECRET_KEY_BASE=                       # openssl rand -hex 64
FRONTEND_URL=https://chat.warehouse14.de
RAILS_ENV=production
NODE_ENV=production
INSTALLATION_ENV=docker
# Lock down public signup — this is a private, single-tenant instance.
ENABLE_ACCOUNT_SIGNUP=false
DEFAULT_LOCALE=de

# ── Postgres (matches the compose) ──────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DATABASE=chatwoot
POSTGRES_USERNAME=chatwoot
POSTGRES_PASSWORD=                      # openssl rand -hex 24  (also used by the compose)

# ── Redis (matches the compose) ─────────────────────────────────────────────
REDIS_PASSWORD=                         # openssl rand -hex 24  (also used by the compose)
REDIS_URL=redis://:REPLACE_WITH_REDIS_PASSWORD@redis:6379

# ── Email (optional — for agent invites / notifications) ────────────────────
# MAILER_SENDER_EMAIL=Warehouse14 <support@warehouse14.de>
# SMTP_ADDRESS=
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=

# ── Storage (optional — reuse the existing Cloudflare R2) ───────────────────
# ACTIVE_STORAGE_SERVICE=s3_compatible
# STORAGE_BUCKET_NAME=
# STORAGE_ACCESS_KEY_ID=
# STORAGE_SECRET_ACCESS_KEY=
# STORAGE_REGION=auto
# STORAGE_ENDPOINT=https://<account>.r2.cloudflarestorage.com
