# ──────────────────────────────────────────────────────────────────────────
# Warehouse14 production env — copy to `.env` next to docker-compose.prod.yml,
# fill the secrets, then `docker compose -f docker-compose.prod.yml up -d`.
# NEVER commit the filled `.env`. Generate keys with:  openssl rand -hex 32
# (DATABASE_URL / REDIS_URL are set by the compose file — do not add them here.)
# ──────────────────────────────────────────────────────────────────────────

# ── Images (GitHub Container Registry) ──────────────────────────────────────
GHCR_OWNER=963s
IMAGE_TAG=latest

# ── Database passwords (used by postgres initdb + the app/migrate URLs) ──────
POSTGRES_SUPERUSER_PASSWORD=        # superuser; never used by the app at runtime
MIGRATOR_PASSWORD=                  # warehouse14_migrator (runs migrations)
APP_PASSWORD=                       # warehouse14_app (api runtime)
WORKER_PASSWORD=                    # warehouse14_worker (worker runtime; separate least-priv role)

# ── Cloudflare Tunnel (TLS + mTLS for api.warehouse14.de) ───────────────────
# Create a tunnel in Cloudflare Zero Trust → copy its token here. Route
# api.warehouse14.de → http://api:3001 and enable Access → mutual TLS on it.
CLOUDFLARE_TUNNEL_TOKEN=

# ── Core app secrets (REQUIRED) ─────────────────────────────────────────────
AUTH_SECRET=                        # session signing — openssl rand -hex 32
WAREHOUSE14_PII_KEY=                # PII-at-rest encryption — openssl rand -hex 32
# Desktop apps run in a Tauri webview → add its origins so CORS allows them.
TRUSTED_ORIGINS=https://api.warehouse14.de,http://tauri.localhost,https://tauri.localhost,tauri://localhost
TRANSACTION_STEP_UP_THRESHOLD_EUR=2000
LOG_LEVEL=info

# ── TEST-ONLY pre-mTLS escape hatch (REMOVE at go-live) ─────────────────────
# Until Cloudflare Access mTLS is enabled, there is no client cert, so every
# device-gated request would be hard-refused. Set this to a seeded device's
# fingerprint to let uncerted requests act as that one device. UNSET the moment
# real mTLS is live. Empty = off (the secure default).
TEST_DEVICE_FINGERPRINT=

# ── Cloudflare R2 (media / TSE archives) — REQUIRED for photos + exports ────
R2_ACCOUNT_ID=
R2_BUCKET=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PUBLIC_URL_BASE=

# ── Optional integrations — empty = feature degrades safely / is off ────────
# AI (vision + WhatsApp bot)
ANTHROPIC_API_KEY=
# Online store (Stripe)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_API_VERSION=2024-12-18.acacia
STRIPE_WEBHOOK_TOLERANCE_SECONDS=300
# eBay instant delisting (Trading API)
EBAY_API_TOKEN=
# eBay listing PUSH (Sell Inventory API). Empty EBAY_OAUTH_TOKEN → not
# configured: the POS "Bei eBay listen" shows a German "token pending" toast
# and makes no live listing. The three policy ids must be set together or none.
EBAY_OAUTH_TOKEN=
EBAY_MARKETPLACE=EBAY_DE
EBAY_SELL_API_BASE_URL=https://api.ebay.com
EBAY_MERCHANT_LOCATION_KEY=
EBAY_FULFILLMENT_POLICY_ID=
EBAY_PAYMENT_POLICY_ID=
EBAY_RETURN_POLICY_ID=
EBAY_DEFAULT_CATEGORY_ID=
# WhatsApp (Meta Graph)
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
# Worker: TSE cert checker (Fiskaly) — server-side cert-expiry monitor
FISKALY_API_KEY=
FISKALY_API_SECRET=
FISKALY_TSS_ID=
# Worker: metal-price feed
METAL_PRICE_PROVIDER=
METAL_PRICE_API_KEY=
